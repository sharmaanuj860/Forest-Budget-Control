rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         request.auth.token.email == "sharmaanuj860@gmail.com" ||
         request.auth.token.email.lower() == "admin@rajgarhforest.app");
    }
    
    function isDEO() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'deo' ||
         request.auth.token.email.lower() == "da123@rajgarhforest.app");
    }

    function canWrite() {
      return isAdmin() || isDEO();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /financialYears/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /ranges/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /schemes/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /sectors/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /activities/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /subActivities/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /soeHeads/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /allocations/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }

    match /expenditures/{id} {
      allow read: if isAuthenticated();
      allow create, update: if canWrite();
      allow delete: if isAdmin();
    }
  }
}
