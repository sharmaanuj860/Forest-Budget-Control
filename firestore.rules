rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: payees
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - Payee name
    //   - address: string (required) - Payee address
    //   - accountNumber: string (required) - Bank account number
    //   - rangeId: string (optional) - Associated range ID
    //   - createdBy: string (required) - Creator UID
    //   - createdAt: number (required) - Creation timestamp
    //   - updatedAt: number (required) - Update timestamp
    //
    // ===============================================================
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "sharmaanuj860@gmail.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email != null && request.auth.token.email.toLower() == "admin@rajgarhforest.app" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    
    function isDEO() {
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.toLower() == "da123@rajgarhforest.app" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'deo')
      );
    }

    function isApprover() {
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.toLower() == "da789@rajgarhforest.app" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'approver')
      );
    }

    function isDA() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'DA');
    }

    function canWrite() {
      return isAdmin() || isDEO();
    }

    function canWriteExpenditure(data) {
      return isAuthenticated() && 
        (isAdmin() || isDEO() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          exists(/databases/$(database)/documents/ranges/$(('rangeId' in data) ? data.rangeId : get(/databases/$(database)/documents/allocations/$(data.allocationId)).data.rangeId)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == get(/databases/$(database)/documents/ranges/$(('rangeId' in data) ? data.rangeId : get(/databases/$(database)/documents/allocations/$(data.allocationId)).data.rangeId)).data.name));
    }

    function canApproveExpenditure() {
      return isAdmin() || isApprover() || isDA();
    }

    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidPayee(data) {
      return hasRequiredFields(['name', 'address', 'accountNumber', 'createdBy', 'createdAt', 'updatedAt']) &&
             hasOnlyAllowedFields(['name', 'address', 'accountNumber', 'rangeId', 'createdBy', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.accountNumber is string && data.accountNumber.size() > 0 && data.accountNumber.size() < 50 &&
             data.createdBy is string &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidFeatureLock(data) {
      return hasRequiredFields(['feature', 'target', 'isLocked', 'updatedBy', 'updatedAt']) &&
             hasOnlyAllowedFields(['feature', 'target', 'isLocked', 'updatedBy', 'updatedAt']) &&
             data.feature in ['Allocation', 'Expenditure', 'Access'] &&
             data.target is string &&
             data.isLocked is bool &&
             data.updatedBy is string &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeSessions']))
      );
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow get: if true;
    }

    match /financialYears/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /ranges/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /schemes/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /sectors/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /activities/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /subActivities/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /soeHeads/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /approvedBudgets/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /treasuryReceipts/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /soeBudgets/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /allocations/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /expenditures/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && canWriteExpenditure(request.resource.data);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isDEO() && !resource.data.isLocked) ||
        (resource.data.createdBy == request.auth.uid && resource.data.status == 'pending' && !resource.data.isLocked) ||
        canApproveExpenditure()
      );
      allow delete: if isAuthenticated() && (
        isAdmin() ||
        (isDEO() && resource.data.status == 'pending' && (resource.data.createdByRole == 'deo' || resource.data.createdByRole == 'user' || resource.data.createdBy == request.auth.uid) && !resource.data.isLocked) ||
        (resource.data.createdBy == request.auth.uid && resource.data.status == 'pending' && !resource.data.isLocked)
      );
    }

    match /appSettings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || isApprover());
    }

    match /bills/{id} {
      allow read: if isAuthenticated();
      allow create: if canWrite();
      allow update: if isAdmin() || (isDEO() && resource.data.status == 'draft');
      allow delete: if isAdmin() || (isDEO() && resource.data.status == 'draft');
    }

    match /surrenders/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if canWrite();
    }

    match /payees/{id} {
      allow read: if isAuthenticated();
      allow create: if canWrite() && isValidPayee(request.resource.data);
      allow update: if canWrite() && isValidPayee(request.resource.data);
      allow delete: if canWrite();
    }

    match /featureLocks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidFeatureLock(request.resource.data);
    }
  }
}
