{
  "entities": {
    "FinancialYear": {
      "title": "Financial Year",
      "description": "Represents a financial year (e.g., 2025-26)",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the financial year" }
      },
      "required": ["name"]
    },
    "Range": {
      "title": "Range",
      "description": "Represents a forest range",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the range" }
      },
      "required": ["name"]
    },
    "Scheme": {
      "title": "Scheme",
      "description": "Represents a budget scheme",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the scheme" },
        "fyId": { "type": "string", "description": "ID of the financial year" }
      },
      "required": ["name", "fyId"]
    },
    "Sector": {
      "title": "Sector",
      "description": "Represents a sector within a scheme",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the sector" },
        "schemeId": { "type": "string", "description": "ID of the scheme" }
      },
      "required": ["name", "schemeId"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Represents an activity within a sector or scheme",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the activity" },
        "sectorId": { "type": "string", "description": "ID of the sector (optional)" },
        "schemeId": { "type": "string", "description": "ID of the scheme (optional)" }
      },
      "required": ["name"]
    },
    "SubActivity": {
      "title": "Sub Activity",
      "description": "Represents a sub-activity within an activity",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the sub-activity" },
        "activityId": { "type": "string", "description": "ID of the activity" }
      },
      "required": ["name", "activityId"]
    },
    "SOEHead": {
      "title": "SOE Head",
      "description": "Represents an SOE budget head",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the SOE head" },
        "schemeId": { "type": "string", "description": "ID of the scheme (optional)" },
        "sectorId": { "type": "string", "description": "ID of the sector (optional)" },
        "activityId": { "type": "string", "description": "ID of the activity (optional)" },
        "subActivityId": { "type": "string", "description": "ID of the sub-activity (optional)" }
      },
      "required": ["name"]
    },
    "ApprovedBudget": {
      "title": "Approved Budget",
      "description": "Represents an administrative sanction for a specific hierarchy",
      "type": "object",
      "properties": {
        "fyId": { "type": "string", "description": "ID of the financial year" },
        "schemeId": { "type": "string", "description": "ID of the scheme" },
        "sectorId": { "type": "string", "description": "ID of the sector (optional)" },
        "activityId": { "type": "string", "description": "ID of the activity (optional)" },
        "subActivityId": { "type": "string", "description": "ID of the sub-activity (optional)" },
        "amount": { "type": "number", "description": "The sanctioned amount" }
      },
      "required": ["fyId", "schemeId", "amount"]
    },
    "TreasuryReceipt": {
      "title": "Treasury Receipt",
      "description": "Represents physical cash received in the treasury for an SOE head",
      "type": "object",
      "properties": {
        "fyId": { "type": "string", "description": "ID of the financial year" },
        "schemeId": { "type": "string", "description": "ID of the scheme" },
        "sectorId": { "type": "string", "description": "ID of the sector (optional)" },
        "activityId": { "type": "string", "description": "ID of the activity (optional)" },
        "subActivityId": { "type": "string", "description": "ID of the sub-activity (optional)" },
        "soeId": { "type": "string", "description": "ID of the SOE head" },
        "amount": { "type": "number", "description": "The received amount" }
      },
      "required": ["fyId", "schemeId", "soeId", "amount"]
    },
    "Allocation": {
      "title": "Allocation",
      "description": "Represents a budget allocation to a range",
      "type": "object",
      "properties": {
        "rangeId": { "type": "string", "description": "ID of the range" },
        "schemeId": { "type": "string", "description": "ID of the scheme" },
        "sectorId": { "type": "string", "description": "ID of the sector (optional)" },
        "activityId": { "type": "string", "description": "ID of the activity (optional)" },
        "subActivityId": { "type": "string", "description": "ID of the sub-activity (optional)" },
        "amount": { "type": "number", "description": "The sanctioned amount for the range" },
        "status": { "type": "string", "enum": ["Pending SOE Funds", "Funded"], "description": "Funding status" },
        "fundedSOEs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "soeId": { "type": "string" },
              "amount": { "type": "number" }
            }
          }
        }
      },
      "required": ["rangeId", "schemeId", "amount", "status"]
    },
    "Expenditure": {
      "title": "Expenditure",
      "description": "Represents an expenditure entry",
      "type": "object",
      "properties": {
        "allocationId": { "type": "string", "description": "ID of the allocation" },
        "soeId": { "type": "string", "description": "ID of the SOE head being booked against" },
        "amount": { "type": "number", "description": "The expenditure amount" },
        "date": { "type": "string", "description": "The date of expenditure (ISO format)" },
        "description": { "type": "string", "description": "Description of the expenditure" }
      },
      "required": ["allocationId", "soeId", "amount", "date", "description"]
    },
    "User": {
      "title": "User",
      "description": "Represents an application user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "The user's email" },
        "role": { "type": "string", "enum": ["admin", "deo"], "description": "The user's role" }
      },
      "required": ["email", "role"]
    },
    "Bill": {
      "title": "Bill",
      "description": "Represents a treasury bill containing multiple expenditures",
      "type": "object",
      "properties": {
        "billNo": { "type": "string", "description": "The bill number" },
        "billDate": { "type": "string", "description": "The date of the bill" },
        "expenseIds": { "type": "array", "items": { "type": "string" }, "description": "List of expenditure IDs" },
        "fyId": { "type": "string", "description": "ID of the financial year" },
        "financialYear": { "type": "string", "description": "Name of the financial year" },
        "totalAmount": { "type": "number", "description": "Total amount of the bill" },
        "status": { "type": "string", "enum": ["draft", "finalized"], "description": "Status of the bill" },
        "remarks": { "type": "string", "description": "Optional remarks" },
        "createdBy": { "type": "string", "description": "UID of the user who created the bill" }
      },
      "required": ["billNo", "billDate", "expenseIds", "fyId", "financialYear", "totalAmount", "status"]
    },
    "Surrender": {
      "title": "Surrender",
      "description": "Represents a budget surrender entry",
      "type": "object",
      "properties": {
        "rangeId": { "type": "string", "description": "ID of the range" },
        "schemeId": { "type": "string", "description": "ID of the scheme" },
        "sectorId": { "type": "string", "description": "ID of the sector" },
        "activityId": { "type": "string", "description": "ID of the activity" },
        "subActivityId": { "type": "string", "description": "ID of the sub-activity" },
        "soeId": { "type": "string", "description": "ID of the SOE head" },
        "amount": { "type": "number", "description": "The surrendered amount" },
        "date": { "type": "string", "description": "The date of surrender (ISO format)" },
        "remarks": { "type": "string", "description": "Optional remarks" },
        "fyId": { "type": "string", "description": "ID of the financial year" },
        "financialYear": { "type": "string", "description": "Name of the financial year" }
      },
      "required": ["rangeId", "schemeId", "sectorId", "activityId", "subActivityId", "soeId", "amount", "date", "fyId", "financialYear"]
    }
  },
  "firestore": {
    "/financialYears": { "schema": "FinancialYear", "description": "Collection of financial years" },
    "/ranges": { "schema": "Range", "description": "Collection of forest ranges" },
    "/schemes": { "schema": "Scheme", "description": "Collection of budget schemes" },
    "/sectors": { "schema": "Sector", "description": "Collection of sectors" },
    "/activities": { "schema": "Activity", "description": "Collection of activities" },
    "/subActivities": { "schema": "SubActivity", "description": "Collection of sub-activities" },
    "/soeHeads": { "schema": "SOEHead", "description": "Collection of SOE heads" },
    "/approvedBudgets": { "schema": "ApprovedBudget", "description": "Collection of administrative sanctions" },
    "/treasuryReceipts": { "schema": "TreasuryReceipt", "description": "Collection of physical cash receipts" },
    "/allocations": { "schema": "Allocation", "description": "Collection of budget allocations" },
    "/expenditures": { "schema": "Expenditure", "description": "Collection of expenditures" },
    "/users": { "schema": "User", "description": "Collection of application users" },
    "/bills": { "schema": "Bill", "description": "Collection of treasury bills" },
    "/surrenders": { "schema": "Surrender", "description": "Collection of budget surrenders" }
  }
}
